{
  "name": "@research-ide/desktop",
  "productName": "Research IDE",
  "version": "0.2.0",
  "description": "A local-first research writing and development environment.",
  "author": "Research IDE contributors",
  "license": "MIT",
  "private": true,
  "main": ".vite/build/index.js",
  "config": {
    "forge": "./forge.config.ts"
  },
  "scripts": {
    "dev": "electron-forge start",
    "start": "electron-forge start",
    "build": "electron-forge package",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint src *.ts",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit",
    "test": "vitest run --config ../../vitest.config.ts",
    "test:watch": "vitest --config ../../vitest.config.ts",
    "e2e": "playwright test --config ../../playwright.config.ts"
  },
  "dependencies": {
