{
  "name": "research-ide",
  "version": "0.2.0",
  "private": true,
  "description": "A local-first, cross-platform desktop IDE for research workflows.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.13.0 <25",
    "pnpm": ">=9.15.0 <10"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "3.4.12"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @research-ide/desktop dev",
    "build": "pnpm verify:release && pnpm --filter @research-ide/desktop build",
    "package": "pnpm verify:release && pnpm --filter @research-ide/desktop package",
    "make": "pnpm verify:release && pnpm --filter @research-ide/desktop make",
    "rebuild:native": "pnpm --filter @research-ide/desktop rebuild:native",
    "verify:release": "node scripts/verify-release-version.mjs",
    "lint": "eslint .",
    "typecheck": "pnpm --filter @research-ide/desktop typecheck",
    "test": "pnpm --filter @research-ide/desktop test",
    "e2e": "pnpm --filter @research-ide/desktop e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm verify:release && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "eslint": "9.39.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "15.14.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  }
}
